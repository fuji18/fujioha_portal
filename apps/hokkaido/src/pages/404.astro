---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortalTop from '@fujioha/ui/components/PortalTop.astro';
import PortalFooter from '@fujioha/ui/components/PortalFooter.astro';
---

<BaseLayout
  title="404 — hokkaido.fujioha.com"
  description="ページが見つかりませんでした。"
>
  <div class="hk">
    <PortalTop sub="hokkaido" subJp="北海道の歩き方" />

    <section class="hk-section">
      <div class="hk-eyebrow fp-mono">404 · Not found</div>
      <h1 class="hk-h2 fp-jp">その道は、まだありません。</h1>
      <p class="hk-h2-en fp-en fp-mute">This page isn't here.</p>
      <p style="margin-top: 24px;">
        <a class="pc-link fp-mono" href="/">← トップへ戻る / Back home</a>
      </p>
    </section>

    <PortalFooter
      sub="hokkaido"
      siblingSub="game"
      siblingJp="思いつきの Web ゲーム"
      siblingEn="Small web games, made by hand"
      siblingHref="https://game.fujioha.com"
    />
  </div>
</BaseLayout>
