---
import NorenScene from './NorenScene.astro';
import { isOpen, shopHref, type Shop } from '../lib/alley';

type Props = Shop;

const shop = Astro.props;
const { jp, en, sub, tag, color, dashed = false } = shop;

const open = isOpen(shop);
const href = shopHref(shop);

// 営業中はリンク、準備中は非リンク要素として描画する。
const Wrapper = open ? 'a' : 'div';
---

<Wrapper
  class={['fp-noren', dashed && 'is-dashed', open && 'is-open']
    .filter(Boolean)
    .join(' ')}
  href={open ? href : undefined}
  aria-label={open ? `${jp} (${en}) — ${sub}.fujioha.com へ` : undefined}
>
  <div class="fp-noren-window">
    <NorenScene sub={sub} />
  </div>
  <div class="fp-noren-cloth" style={`background: ${color}`}>
    <div class="fp-noren-label fp-jp">{jp}</div>
    <div class="fp-noren-label-en fp-en">{en}</div>
    <div class="fp-noren-slits">
      <div class="fp-noren-slit"></div>
      <div class="fp-noren-slit"></div>
      <div class="fp-noren-slit"></div>
      <div class="fp-noren-slit"></div>
    </div>
  </div>
  <div class="fp-noren-plate">
    <div class="fp-noren-name">
      <span class="fp-jp">{jp}</span>
      <span class="fp-en fp-noren-name-en">{en}</span>
    </div>
    <div class="fp-mono">{sub}.fujioha.com</div>
    <div class="fp-noren-tag fp-faint">{tag}</div>
  </div>
</Wrapper>
