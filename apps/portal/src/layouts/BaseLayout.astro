---
import '../styles/global.css';
import SeoHead from '@fujioha/ui/components/SeoHead.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'fujioha.com — おはよう',
  description = '個人がつくる小さなサイトの通り。北海道の歩き方と、思いつきの Web ゲーム。',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <SeoHead title={title} description={description} image="/og.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="fujioha.com — 最近の更新"
      href="/rss.xml"
    />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="fujioha.com — 最近の更新"
      href="/atom.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Shippori+Mincho+B1:wght@400;500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
