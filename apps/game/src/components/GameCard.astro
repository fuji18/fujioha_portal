---
import GameIcon from './GameIcon.astro';
import type { Game } from '../lib/games';

type Props = Game;

const { jp, en, genre, genreEn, time, tag, icon, hue, url, status, image } =
  Astro.props;

const playable = status === 'published' && !!url && tag !== 'wip';
const href = playable ? url! : '#';
const label = tag === 'wip' ? '準備中' : playable ? '遊ぶ' : '準備中';
const labelEn = tag === 'wip' ? 'Coming soon' : playable ? 'Play' : 'Coming soon';
// 外部スポークは別オリジンなので noopener/noreferrer/外部リンク扱い
const isExternal = playable && url!.startsWith('http');
---

<a
  class="gm-card"
  href={href}
  data-genre={genre}
  aria-disabled={!playable}
  {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  <div class="gm-card-art" style={`--hue: ${hue}`}>
    {image ? (
      <img class="gm-card-thumb" src={image} alt={jp} />
    ) : (
      <GameIcon kind={icon} hue={hue} />
    )}
    {
      tag && (
        <span class={`gm-card-flag gm-flag-${tag}`}>
          {tag === 'new' ? 'NEW' : 'WIP'}
        </span>
      )
    }
  </div>
  <div class="gm-card-body">
    <h3 class="gm-card-jp fp-jp">{jp}</h3>
    <p class="gm-card-en fp-en fp-mute">{en}</p>
    <div class="gm-card-foot">
      <span class="gm-card-genre">
        <span class="fp-jp">{genre}</span>
        <span class="fp-en fp-faint"> · {genreEn}</span>
      </span>
      <span class="gm-card-time fp-mono fp-faint">{time}</span>
    </div>
    <div class="gm-card-play">
      <span class="gm-play-icon">▶</span>
      <span class="fp-jp">{label}</span>
      <span class="fp-en fp-mute">{labelEn}</span>
    </div>
  </div>
</a>

<style>
  .gm-card-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
