---
import { getCollection } from 'astro:content';
import SectionHead from './SectionHead.astro';
import GameCard from './GameCard.astro';
import { GENRES } from '../lib/games';

const entries = await getCollection('games');
const games = entries
  .map((entry) => entry.data)
  .sort((a, b) => {
    // published を先頭、次に featured、次に publishedAt 降順
    if (a.status !== b.status) {
      const rank = { published: 0, draft: 1, archived: 2 } as const;
      return rank[a.status] - rank[b.status];
    }
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    if (a.publishedAt && b.publishedAt) {
      return b.publishedAt.localeCompare(a.publishedAt);
    }
    return 0;
  });
---

<section class="gm-section">
  <SectionHead
    eyebrow="ぜんぶの棚 · The shelf"
    jp="ほかのゲーム。"
    en="Everything else on the shelf."
  >
    <div slot="right" class="gm-filters" data-filters>
      {
        GENRES.map((g, i) => (
          <button
            type="button"
            class={`gm-filter ${i === 0 ? 'is-on' : ''}`}
            data-genre={i === 0 ? 'all' : g.split(' / ')[0]}
          >
            {g}
          </button>
        ))
      }
    </div>
  </SectionHead>
  <div class="gm-grid" data-grid>
    {games.map((g) => <GameCard {...g} />)}
  </div>
</section>

<script is:inline>
  (function () {
    const filters = document.querySelector('[data-filters]');
    const grid = document.querySelector('[data-grid]');
    if (!filters || !grid) return;
    filters.addEventListener('click', function (e) {
      const btn = e.target.closest('.gm-filter');
      if (!btn) return;
      const genre = btn.getAttribute('data-genre');
      filters.querySelectorAll('.gm-filter').forEach(function (b) {
        b.classList.toggle('is-on', b === btn);
      });
      grid.querySelectorAll('.gm-card').forEach(function (card) {
        const match =
          genre === 'all' || card.getAttribute('data-genre') === genre;
        card.style.display = match ? '' : 'none';
      });
    });
  })();
</script>
