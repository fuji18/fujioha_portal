{
  "name": "fujioha-platform",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:portal": "npm run dev --workspace=@fujioha/portal",
    "dev:hokkaido": "npm run dev --workspace=@fujioha/hokkaido",
    "dev:game": "npm run dev --workspace=@fujioha/game",
    "build": "npm run build --workspaces --if-present",
    "preview:portal": "npm run preview --workspace=@fujioha/portal",
    "preview:hokkaido": "npm run preview --workspace=@fujioha/hokkaido",
    "preview:game": "npm run preview --workspace=@fujioha/game",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "astro": "^5.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^2.1.8"
  }
}
